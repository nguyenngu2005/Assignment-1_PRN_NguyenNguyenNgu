@model NguyenNguyenNguMVC.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | FU News Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            /* Modern Color Palette & Background */
            body {
                background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
                margin: 0;
            }

            /* Glassmorphism Card */
            .glass-card {
                background: rgba(255, 255, 255, 0.05);
                backdrop-filter: blur(15px);
                -webkit-backdrop-filter: blur(15px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 1.5rem;
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
                overflow: hidden;
                width: 100%;
                max-width: 900px;
            }

            /* Split-screen layout styling */
            .login-sidebar {
                background: rgba(0, 0, 0, 0.2);
                padding: 3rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
            }

            .login-form-area {
                padding: 3rem;
            }

            .text-gradient {
                background: linear-gradient(to right, #00c6ff, #0072ff);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                font-weight: 700;
            }

            /* Custom Input Fields */
            .form-control-glass {
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.2);
                color: white;
                border-radius: 0.75rem;
                padding: 0.75rem 1rem;
                transition: all 0.3s ease;
            }

            .form-control-glass:focus {
                background: rgba(255, 255, 255, 0.15);
                border-color: #00c6ff;
                color: white;
                box-shadow: 0 0 0 0.25rem rgba(0, 198, 255, 0.25);
            }

            .form-control-glass::placeholder {
                color: rgba(255, 255, 255, 0.5);
            }

            /* Input Group styling for Show/Hide Password */
            .input-group-text-glass {
                background: rgba(255, 255, 255, 0.08);
                border: 1px solid rgba(255, 255, 255, 0.2);
                border-left: none;
                color: rgba(255, 255, 255, 0.6);
                cursor: pointer;
                border-top-right-radius: 0.75rem;
                border-bottom-right-radius: 0.75rem;
                transition: color 0.3s ease;
            }

            .input-group-text-glass:hover {
                color: white;
            }

            .form-control-glass.border-end-0 {
                border-right: none;
            }

            /* Custom Button */
            .btn-gradient {
                background: linear-gradient(to right, #00c6ff, #0072ff);
                border: none;
                border-radius: 0.75rem;
                color: white;
                font-weight: 600;
                padding: 0.75rem;
                transition: transform 0.2s, box-shadow 0.2s;
            }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0, 114, 255, 0.4);
                color: white;
            }

            /* Label and Validation */
            .form-label {
                color: rgba(255, 255, 255, 0.9);
                font-weight: 500;
                font-size: 0.9rem;
            }

            .text-danger {
                color: #ff6b6b !important;
                font-size: 0.85rem;
                margin-top: 0.25rem;
                display: block;
            }

            /* Toast Alert */
            .custom-alert {
                background: rgba(255, 107, 107, 0.1);
                border: 1px solid rgba(255, 107, 107, 0.3);
                color: #ff6b6b;
                border-radius: 0.75rem;
            }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center align-items-center">
        <div class="row glass-card">

            <div class="col-md-5 login-sidebar d-none d-md-flex text-center text-white">
                <i class="bi bi-globe2 display-1 mb-4 text-gradient"></i>
                <h2 class="fw-bold mb-3">FUNews<br>Management</h2>
                <p class="text-white-50">Streamline your academic publishing and stay connected with the university network.</p>
            </div>

            <div class="col-md-7 login-form-area">
                <div class="text-center mb-5 d-md-none text-white">
                    <h2 class="fw-bold text-gradient">FUNews</h2>
                </div>

                <h3 class="text-white fw-bold mb-1">Welcome back</h3>
                <p class="text-white-50 mb-4">Please enter your details to sign in.</p>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert custom-alert d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <div>@ViewBag.ErrorMessage</div>
                    </div>
                }

                <form asp-controller="Login" asp-action="Index" method="post">

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control form-control-glass" placeholder="admin@FUNewsManagementSystem.org" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Password" type="password" id="passwordInput" class="form-control form-control-glass border-end-0" placeholder="••••••••" />
                            <span class="input-group-text input-group-text-glass" id="togglePassword">
                                <i class="bi bi-eye-slash" id="toggleIcon"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-gradient w-100 mt-2 mb-3">
                        Sign In <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        // Toggle Password Visibility
        document.getElementById('togglePassword').addEventListener('click', function () {
        const passwordInput = document.getElementById('passwordInput');
        const toggleIcon = document.getElementById('toggleIcon');

        if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        toggleIcon.classList.remove('bi-eye-slash');
        toggleIcon.classList.add('bi-eye');
        } else {
        passwordInput.type = 'password';
        toggleIcon.classList.remove('bi-eye');
        toggleIcon.classList.add('bi-eye-slash');
        }
        });
    </script>
</body>
</html>