@model IEnumerable<Repositories.Models.SystemAccount>
@{
    ViewData["Title"] = "Quản lý Tài Khoản";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Khu vực Admin: Quản lý Tài khoản</h2>
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createAccountModal">
            <i class="bi bi-person-plus-fill me-1"></i> Thêm Tài Khoản
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Tên Người Dùng</th>
                        <th>Email Đăng Nhập</th>
                        <th class="text-center">Vai Trò (Role)</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.AccountId</td>
                            <td><span class="fw-bold text-secondary">@item.AccountName</span></td>
                            <td>@item.AccountEmail</td>
                            <td class="text-center">
                                @if (item.AccountRole == 0)
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else if (item.AccountRole == 1)
                                {
                                    <span class="badge bg-primary">Staff</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Lecturer</span>
                                }
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-primary"
                                        onclick="openEditAccountModal('@item.AccountId', '@Html.Raw(item.AccountName?.Replace("'", "\\'"))', '@item.AccountEmail', '@Html.Raw(item.AccountPassword?.Replace("'", "\\'"))', '@item.AccountRole')">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger ms-1"
                                        onclick="confirmDeleteAccount('@item.AccountId')">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </button>
                                <form id="deleteAccountForm-@item.AccountId" asp-action="Delete" asp-route-id="@item.AccountId" method="post" style="display:none;"></form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-person-plus"></i> Tạo Tài Khoản Mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mã tài khoản (ID) <span class="text-danger">*</span></label>
                        <input type="number" name="AccountId" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên hiển thị <span class="text-danger">*</span></label>
                        <input type="text" name="AccountName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                        <input type="email" name="AccountEmail" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                        <input type="password" name="AccountPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Phân quyền vai trò</label>
                        <select name="AccountRole" class="form-select">
                            <option value="1">Staff (Nhân viên)</option>
                            <option value="2">Lecturer (Giảng viên)</option>
                            <option value="0">Admin (Quản trị viên)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">Tạo mới</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Edit" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Hiệu Chỉnh Tài Khoản</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editAccountId" name="AccountId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên hiển thị <span class="text-danger">*</span></label>
                        <input type="text" id="editAccountName" name="AccountName" class="form-control" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email đăng nhập <span class="text-danger">*</span></label>
                        <input type="email" id="editAccountEmail" name="AccountEmail" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                        <input type="text" id="editAccountPassword" name="AccountPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Phân quyền vai trò</label>
                        <select id="editAccountRole" name="AccountRole" class="form-select">
                            <option value="0">Admin</option>
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm đổ dữ liệu vào Form Modal Edit khi click nút Sửa
        function openEditAccountModal(id, name, email, password, role) {
            document.getElementById('editAccountId').value = id;
            document.getElementById('editAccountName').value = name;
            document.getElementById('editAccountEmail').value = email;
            document.getElementById('editAccountPassword').value = password;
            document.getElementById('editAccountRole').value = role;

            var modal = new bootstrap.Modal(document.getElementById('editAccountModal'));
            modal.show();
        }

        // Xác nhận chắc chắn trước khi xóa bài viết
        function confirmDeleteAccount(id) {
            if (confirm('Bạn có hoàn toàn chắc chắn muốn xóa tài khoản này khỏi hệ thống không?')) {
                document.getElementById('deleteAccountForm-' + id).submit();
            }
        }
    </script>
}