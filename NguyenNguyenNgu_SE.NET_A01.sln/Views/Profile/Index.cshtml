@model Repositories.Models.SystemAccount
@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-person-circle me-2"></i> Hồ Sơ Của Tôi</h4>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="UpdateProfile" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted">Mã ID</label>
                                <input type="text" class="form-control bg-light" value="@Model.AccountId" readonly />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Vai trò (Role)</label>
                                <input type="text" class="form-control bg-light" value="@(Model.AccountRole == 0 ? "Admin" : (Model.AccountRole == 1 ? "Staff" : "Lecturer"))" readonly />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên hiển thị <span class="text-danger">*</span></label>
                            <input type="text" name="AccountName" class="form-control" value="@Model.AccountName" required maxlength="100" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email đăng nhập <span class="text-danger">*</span></label>
                            <input type="email" name="AccountEmail" class="form-control" value="@Model.AccountEmail" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="password" id="passwordInput" name="AccountPassword" class="form-control" value="@Model.AccountPassword" required />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
                                    <i class="bi bi-eye" id="toggleIcon"></i>
                                </button>
                            </div>
                            <small class="text-muted">Cập nhật mật khẩu mới tại đây nếu muốn thay đổi.</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-save me-1"></i> Lưu Thay Đổi</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-light">Quay lại trang chủ</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword() {
        var pwd = document.getElementById("passwordInput");
        var icon = document.getElementById("toggleIcon");
        if (pwd.type === "password") {
            pwd.type = "text";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        } else {
            pwd.type = "password";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        }
    }
</script>